<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TransportControl.Themes.DarkTheme">
    <!--Blue-->
    <Color x:Key="PrimaryColor">#2196F3</Color>

    <!--Dark Blue-->
    <Color x:Key="PrimaryDarkColor">#0a6ebd</Color>

    <!--White-->
    <Color x:Key="PrimaryTintColor">#FFFFFF</Color>

    <!--Dark Grey-->
    <Color x:Key="PageBackgroundColor">#141414</Color>

    <!--Blue-->
    <Color x:Key="NavigationBarColor">#2196F3</Color>

    <!--White-->
    <Color x:Key="PrimaryTextColor">#ffffff</Color>

    <!--Smoke White-->
    <Color x:Key="SecondaryTextColor">#bdbdbd</Color>

    <!--Dark Smoke White-->
    <Color x:Key="SubTextColor">#a5a5a5</Color>

    <!--White-->
    <Color x:Key="OverlayTextColor">#FFFFFF</Color>

    <!--Transperant Black-->
    <Color x:Key="TransperantBackgroundColor">#56000000</Color>

    <!--Silver Light Grey-->
    <Color x:Key="SeparatorLineColor">#464646</Color>
</ResourceDictionary>